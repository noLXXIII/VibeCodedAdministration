# Access Tokens pro Team
# Kopiere diese Datei zu .env und trage die echten Tokens ein.
# .env wird NICHT committet (siehe .gitignore).

TEAM1_ACCESS_TOKEN=
TEAM2_ACCESS_TOKEN=
TEAM3_ACCESS_TOKEN=
TEAM4_ACCESS_TOKEN=

# Authentik (zentrale Auth-Instanz unter /auth)
AUTHENTIK_PG_USER=authentik
AUTHENTIK_PG_DB=authentik
AUTHENTIK_PG_PASS=
AUTHENTIK_SECRET_KEY=

# Let's Encrypt (HTTPS-Zertifikate via Traefik)
ACME_EMAIL=
